# Amazon Location Service (Places v2)
# Copy this file to ".env" and paste your key from the AWS console.
# Never commit .env (it is gitignored).
#
# API key actions: enable Autocomplete for suggestions; enable GetPlace (preferred)
# or Geocode to resolve coordinates after the user picks a row.

VITE_AWS_LOCATION_API_KEY=
VITE_AWS_LOCATION_REGION=us-west-2
